{
  "name": "s-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Deterministic-first semantic code review guard for TypeScript projects.",
  "type": "commonjs",
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "lint": "tsc -b --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "analyze:demo": "pnpm run analyze:demo:clean",
    "analyze:demo:clean": "pnpm --filter @s-agent/cli run analyze --project ../../examples/demo-clean",
    "analyze:demo:broken": "pnpm --filter @s-agent/cli run analyze --project ../../examples/demo-broken",
    "analyze:self": "pnpm --filter @s-agent/cli run analyze --project ../.. --rules ../../rules --json",
    "rules:validate": "pnpm --filter @s-agent/cli run rules:validate --rules ../../rules"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "packageManager": "pnpm@9.15.0"
}
